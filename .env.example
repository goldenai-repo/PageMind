# Copy to .env.local and fill in from Supabase → Connect / Settings → API Keys
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Google OAuth (configured in Supabase Dashboard + Google Cloud Console, not here):
# 1. Enable Google under Authentication → Providers
# 2. Add redirect URL: http://localhost:3000/auth/callback
# 3. In Google Cloud, Authorized redirect URI must be:
#    https://YOUR_PROJECT_REF.supabase.co/auth/v1/callback
